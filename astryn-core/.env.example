# ── Required ──────────────────────────────────────────────────────────────────

# Shared secret between astryn-core and astryn-telegram.
# Set to any string — just use the same value in both .env files.
ASTRYN_API_KEY=change-me

# ── LLM provider ─────────────────────────────────────────────────────────────

# The model to use. Any Ollama-compatible model that supports tool use works.
# Suggestions: qwen2.5-coder:7b, llama3.1:8b
ASTRYN_DEFAULT_MODEL=qwen2.5-coder:7b

# Uncomment and set when switching to Anthropic (Claude) as the provider.
# ANTHROPIC_API_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────

# Number of conversation turns to keep in memory (each turn = 1 user + 1 assistant message).
MAX_HISTORY_TURNS=20

# Ollama URL. When running via Docker Compose this is set automatically.
# Only override this if you're running astryn-core outside of Docker.
# OLLAMA_BASE_URL=http://localhost:11434
