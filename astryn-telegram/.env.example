# From @BotFather on Telegram (/newbot)
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user ID — get it from @userinfobot on Telegram
ALLOWED_USER_ID=

# Must match ASTRYN_API_KEY in astryn-core/.env
ASTRYN_CORE_API_KEY=change-me

# Set automatically by Docker Compose.
# Only set this manually if running without Docker.
ASTRYN_CORE_URL=http://localhost:8000
